# ── Database (provided automatically by Railway PostgreSQL plugin) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Admin email: where form submissions get sent ──
ADMIN_EMAIL=you@example.com

# ── Resend API key (preferred — takes priority over SMTP_* vars) ──
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Generic SMTP fallback (only used if RESEND_API_KEY is not set) ──
# For SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=<your-api-key>
# For Gmail: host=smtp.gmail.com, port=587, secure=false, user=you@gmail.com, pass=<app-password>
#SMTP_HOST=smtp.sendgrid.net
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=apikey
#SMTP_PASS=your-smtp-password

# ── Email sender identity ──
EMAIL_FROM_NAME=The Salon Agent
EMAIL_FROM_EMAIL=hello@thesalonagent.com

# ── Simple token to protect GET /api/submissions ──
ADMIN_TOKEN=changeme-to-a-random-secret

# ── Server port (Railway sets this automatically) ──
PORT=3000
